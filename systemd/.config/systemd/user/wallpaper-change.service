
[Unit]
Description=Hyprland Random Wallpaper Changer
# Assicura che parta solo dopo che l'ambiente grafico è attivo
After=graphical-session.target

[Service]
Type=simple
# Sostituisci il percorso con quello reale del tuo script
ExecStart=%h/.local/bin/change-wallpaper.sh
# Se lo script crasha o viene terminato, systemd proverà a riavviarlo
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
